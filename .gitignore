# ── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ─────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data — never commit raw dataset or processed files
data/
data/raw/*
data/processed/*
data/yolo_dataset/images/
data/yolo_dataset/labels/
!data/**/.gitkeep

# ── Model Weights & Training Artifacts ──────────────
runs/
*.pt
*.pth
*.onnx
*.torchscript
!runs/.gitkeep

# ── Outputs ─────────────────────────────────────────
outputs/*
!outputs/.gitkeep
logs/*
!logs/.gitkeep

# ── Secrets ─────────────────────────────────────────
.env
*.env

# ── OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Coverage & Testing ──────────────────────────────
.coverage
htmlcov/
.pytest_cache/